# Copia estos valores (NO este archivo con secretos reales) a:
#   apps/commercial/.env.local  -> lo carga el runtime de eve (tools del agente)
#   apps/web/.env.local    -> lo carga Next.js (página /leads)
# Los archivos .env* reales están gitignoreados; nunca los commitees.

# Google Places API (New) — para search_businesses / fetchPlaceDetails
GOOGLE_PLACES_API_KEY=

# Supabase (local: URL http://127.0.0.1:54321; keys salen de `supabase status`)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase auth en el browser (apps/web/.env.local) — key publicable, no secreta
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# eve — providers directos (sin Vercel AI Gateway)
# OPENAI_API_KEY:    root + lead-finder/proposal/outreach/design-scout/brand-curator
# ANTHROPIC_API_KEY: subagente site-builder (claude-sonnet-5)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ALIBABA_API_KEY=

# Correo de "tarea terminada" (Capa 3, react-email + Resend). Sin RESEND_API_KEY
# el envío es no-op. EMAIL_FROM debe ser un remitente verificado en Resend
# (default onboarding@resend.dev). DASHBOARD_URL: base para los links del correo.
RESEND_API_KEY=
EMAIL_FROM=
DASHBOARD_URL=

# Toggle de modelo del site-builder (ORQUESTADOR del build): "gpt" → gpt-5.4
# (frontier coding, $2.5/$15); "gpt-mini" → gpt-5.4-mini ($0.75/$4.5); "qwen" →
# qwen3.7-plus (Alibaba $0.4/$1.6, requiere ALIBABA_API_KEY); vacío/"sonnet" →
# claude-sonnet-5 (default). El bulk lo hacen los tools (ver TOOL_MODEL_* abajo),
# así que aquí conviene un modelo OBEDIENTE. Se lee al compilar: dev = reinicia
# el dev server; prod = Vercel (kreatos-agent) + redeploy.
SITE_BUILDER_MODEL=

# Toggle de modelo del art-director (compone specs): "gpt" → gpt-5.4;
# vacío → claude-sonnet-5 (default).
ART_DIRECTOR_MODEL=

# Modelo INTERNO de los tools por TIPO DE TAREA (lib/tool-models.ts), formato
# "provider:model" (provider = openai|anthropic|alibaba). Vacío = el default de
# la derecha. Regla: abarata generación/transcripción/traducción; NUNCA el juez
# visual (es el gate de calidad). Un solo lugar para A/B por tarea.
#   codegen        (draft_section)              → alibaba:qwen3.7-plus
#   translate      (translate_copy)             → alibaba:qwen3.7-plus
#   transcribe     (draft_surface theme/fonts)  → openai:gpt-5-nano
#   vision-extract (view_reference/capture)     → openai:gpt-5-mini
#   vision-judge   (review_screenshots · GATE)  → anthropic:claude-sonnet-5
#   brand-vision   (analyze_brand_image)        → openai:gpt-5-mini
TOOL_MODEL_CODEGEN=
TOOL_MODEL_TRANSLATE=
TOOL_MODEL_TRANSCRIBE=
TOOL_MODEL_VISION_EXTRACT=
TOOL_MODEL_VISION_JUDGE=
TOOL_MODEL_BRAND_VISION=

# Modelo del ORQUESTADOR (root). Default gpt-5.1: gpt-5-mini ignoraba las
# reglas de encadenamiento (preguntas redundantes, cadenas cortadas, IDs
# perdidos). "gpt-5-mini" para volver al barato.
ROOT_MODEL=

# Host del deployment de eve que consume el dashboard (apps/web). Por defecto el
# MISMO deployment (withEve monta /eve/v1/* ahí); override para apuntar a otro.
EVE_HOST=

# site-builder — repos de sitios por cliente (apps/commercial/.env.local)
# GITHUB_TOKEN: fine-grained PAT de la org, permisos Contents RW + Administration RW
GITHUB_TOKEN=
GITHUB_ORG=kreatos-sites
SITE_TEMPLATE_REPO=site-template

# site-builder — deploys por sitio vía API de Vercel
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# Email de los commits del agente en repos de sitios. Debe corresponder a una
# cuenta GitHub con acceso al team de Vercel (o Vercel bloquea el deployment).
SITE_GIT_EMAIL=jcampillo1207@gmail.com

# Zona horaria de la operación (Torreón, Coahuila). TZ fija el reloj del
# runtime Node (server components, eve, new Date()) — ponla también en el
# proyecto de Vercel, que corre en UTC/otra región. NEXT_PUBLIC_TIME_ZONE
# es el override del formateo de fechas del dashboard (lib/dates.ts).
TZ=America/Monterrey
NEXT_PUBLIC_TIME_ZONE=America/Monterrey